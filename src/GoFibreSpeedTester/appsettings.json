{
  "SpeedTest": {
    "Url": "https://speedtest.gofibre.co.uk/",
    "IntervalMinutes": 5,
    "TimeoutSeconds": 180,
    "Browser": {
      "Headless": true,
      "BrowserName": "chromium"
    },
    "Page": {
      "StartSelector": "",
      "AcceptCookiesSelector": "",
      "ResultsReadySelector": "",
      "DownloadSelector": "",
      "UploadSelector": "",
      "PingSelector": "",
      "JitterSelector": "",
      "PacketLossSelector": ""
    },
    "OutputCsvPath": "speed-results.csv",
    "AppendHeaderIfNewFile": true,
    "CaptureScreenshotOnFailure": true,
    "FailureScreenshotPath": "last-failure.png",
    "LowDownloadThresholdMbps": 300.0,
    "LowDownloadSnapshotSubfolder": "low-download",
    "SaveLowDownloadSnapshot": true
  }
}
